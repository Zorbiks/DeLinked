{
    "manifest_version": 3,
    "name": "DeLinked",
    "version": "1.0",
    "description": "A translation tool that replaces verbose corporate marketing with what the author actually means.",
    "browser_specific_settings": {
        "gecko": {
            "id": "delinked@zorbiks",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "48": "icons/icon-48.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "icons/icon-48.png"
    },
    "permissions": ["activeTab", "scripting", "storage"],
    "background": {
        "scripts": ["background.js"]
    },
    "content_scripts": [
        {
            "js": ["scripts/content.js"],
            "css": ["styles/debullshitify.css"],
            "matches": ["https://*.linkedin.com/*"]
        }
    ]
}
